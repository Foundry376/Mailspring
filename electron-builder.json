{
  "$schema": "https://raw.githubusercontent.com/electron-userland/electron-builder/master/packages/app-builder-lib/scheme.json",
  "appId": "com.mailspring.mailspring",
  "productName": "Mailspring",
  "copyright": "Copyright (C) 2014-2026 Foundry 376, LLC. All rights reserved.",
  "directories": {
    "app": "app",
    "output": "app/dist",
    "buildResources": "app/build/resources"
  },
  "electronVersion": "39.2.7",
  "asar": true,
  "asarUnpack": [
    "mailsync",
    "mailsync.exe",
    "mailsync.bin",
    "*.so",
    "*.so.*",
    "*.dll",
    "*.pdb",
    "*.node",
    "**/vendor/**",
    "examples/**",
    "**/src/tasks/**",
    "**/src/quickpreview/**",
    "**/static/all_licenses.html",
    "**/static/extensions/**",
    "**/node_modules/spellchecker/**"
  ],
  "files": [
    "**/*",
    "!build/**",
    "!dist/**",
    "!docs/**",
    "!docs_src/**",
    "!script/**",
    "!spec/**",
    "!**/*.md",
    "!**/*.log",
    "!**/*.yml",
    "!**/*.gz",
    "!**/*.zip",
    "!**/*.h",
    "!**/*.cc",
    "!**/*.flow",
    "!**/*.gyp",
    "!**/*.gypi",
    "!**/*.mk",
    "!**/*.dYSM",
    "!**/gh-pages",
    "!**/obj/gen",
    "!**/.deps",
    "!**/node_modules/less/dist/**",
    "!**/node_modules/react/dist/**",
    "!**/node_modules/**/test/**",
    "!**/node_modules/**/tests/**",
    "!**/node_modules/**/coverage/**",
    "!**/node_modules/**/benchmark/**"
  ],
  "fileAssociations": [
    {
      "ext": "*",
      "role": "Viewer",
      "name": "File"
    }
  ],
  "protocols": [
    {
      "name": "Mailspring Protocol",
      "schemes": ["mailspring"]
    },
    {
      "name": "Mailto Protocol",
      "schemes": ["mailto"]
    }
  ],
  "afterPack": "./scripts/electron-builder-hooks.js",
  "mac": {
    "category": "public.app-category.business",
    "icon": "mac/mailspring.icns",
    "extendInfo": "mac/extra.plist",
    "hardenedRuntime": true,
    "entitlements": "mac/entitlements.plist",
    "entitlementsInherit": "mac/entitlements.child.plist",
    "provisioningProfile": "${env.APPLE_PROVISIONING_PROFILE_PATH}",
    "notarize": {
      "teamId": "${env.APPLE_TEAM_ID}"
    },
    "target": [
      {
        "target": "dmg",
        "arch": ["x64", "arm64"]
      },
      {
        "target": "zip",
        "arch": ["x64", "arm64"]
      }
    ]
  },
  "dmg": {
    "background": "mac/DMG-Background.png",
    "sign": false
  },
  "win": {
    "icon": "win/mailspring-square.ico",
    "target": [
      {
        "target": "squirrel",
        "arch": ["x64"]
      }
    ]
  },
  "squirrelWindows": {
    "iconUrl": "http://mailspring-builds.s3.amazonaws.com/assets/mailspring-square.ico",
    "loadingGif": "win/loading.gif",
    "setupIcon": "win/mailspring-square.ico"
  },
  "linux": {
    "executableName": "mailspring",
    "icon": "linux/icons",
    "category": "Network;Email",
    "desktopFile": "app/build/resources/linux/mailspring.desktop",
    "synopsis": "The best email app for people and teams at work",
    "description": "Mailspring is a fast, beautiful email client built on the modern web with Electron. It supports all major mail providers and comes packed with features like unified inbox, snooze, send later, mail rules, and templates.",
    "target": [
      {
        "target": "deb",
        "arch": ["x64", "arm64"]
      },
      {
        "target": "rpm",
        "arch": ["x64", "arm64"]
      }
    ]
  },
  "deb": {
    "depends": [
      "libasound2t64 | libasound2",
      "libatk-bridge2.0-0",
      "libatspi2.0-0",
      "libcurl4t64 | libcurl4",
      "libgbm1",
      "libgcrypt20",
      "libglib2.0-bin",
      "libgtk-3-0t64 (>= 3.10.0) | libgtk-3-0 (>= 3.10.0)",
      "libnotify4",
      "libnss3",
      "libsasl2-2",
      "libsecret-1-0",
      "libssl3",
      "libtidy5deb1 | libtidy58",
      "libudev1",
      "libxss1",
      "libxtst6",
      "xdg-utils"
    ],
    "recommends": [
      "gir1.2-gnomekeyring-1.0"
    ],
    "afterInstall": "linux/debian/postinst",
    "afterRemove": "linux/debian/postrm",
    "fpm": [
      "--category=mail",
      "--deb-lintian-overrides-file=app/build/resources/linux/debian/lintian-overrides"
    ]
  },
  "rpm": {
    "depends": [
      "libsecret",
      "libXScrnSaver",
      "libcurl",
      "libnotify",
      "nss",
      "gtk3",
      "alsa-lib",
      "libgbm",
      "xdg-utils",
      "at-spi2-core"
    ],
    "fpm": [
      "--rpm-rpmbuild-define=_build_id_links none"
    ]
  },
  "publish": null,
  "forceCodeSigning": false
}
